# Azen — Environment Variables
#
# Copy to .env for local development.
# Never commit a real .env. Production values live in Railway service env vars.

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3032

# ─────────────────────────────────────────────────────────────────────────────
# Sovereign database — Postgres-Azen
# Local dev: point at a local Postgres or a Railway-provided database URL.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/azen

# ─────────────────────────────────────────────────────────────────────────────
# Bifrost — all LLM calls flow through here
# Local dev: Ken's Bifrost on port 3033.
# Production: Railway internal URL (http://bifrost.railway.internal:8080)
#             or public URL (https://bifrost-production-1650.up.railway.app)
# ─────────────────────────────────────────────────────────────────────────────
BIFROST_URL=http://localhost:3033

# ─────────────────────────────────────────────────────────────────────────────
# Governance — Four Pillars Gateway + Amata
# Local dev: Governance on port 3010.
# Production (in robust-grace): http://governance.railway.internal:8080
# ─────────────────────────────────────────────────────────────────────────────
GOVERNANCE_URL=http://localhost:3010

# ─────────────────────────────────────────────────────────────────────────────
# NESHAMAH — Sabbath status (optional for Conception; required for Implantation)
# Without this set, the Sabbath gate is disabled.
# ─────────────────────────────────────────────────────────────────────────────
NESHAMAH_SERVICE_URL=http://localhost:3009

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
